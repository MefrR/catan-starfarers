# Client build-time environment variables (Vite).
# Copy to ".env" (or set in your host's build env) and fill in as needed.
# Vite only exposes vars prefixed with VITE_ to the browser bundle.

# URL of the public realtime server used by the "Play Online" button.
#
# Leave UNSET for a single-service deploy (client + server on the same host):
# the client then connects to its own origin automatically.
#
# Set it ONLY when the client is hosted separately from the server
# (e.g. static client on Hostinger, server on Render). It must point at the
# server's public URL, scheme included:
#   VITE_ONLINE_URL=https://play.designroom.studio
VITE_ONLINE_URL=
