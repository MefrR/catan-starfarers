{
  "name": "@starfarers/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.mjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.mjs --external:express --external:socket.io",
    "typecheck": "tsc -p tsconfig.json --emitDeclarationOnly false --noEmit",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "@starfarers/shared": "*",
    "express": "^4.21.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2"
  }
}
