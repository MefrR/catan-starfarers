# Copy the values you need into client/.env.local (local dev) or set them in
# your Render / Vercel dashboard. Real values must NEVER be committed.

# --- Accounts (Supabase) — PUBLIC client keys (safe to ship in the browser) ---
# From Supabase: Project Settings -> API. See SUPABASE_SETUP.md.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Multiplayer: where the online "Play Online" button connects ---
# Only set when the client is hosted separately from the game server
# (e.g. client on Vercel, server on Render). Leave unset for single-service.
# VITE_ONLINE_URL=https://your-game-server.onrender.com

# --- Server-only (Phase 2: writing game results). NEVER expose to the browser;
#     set this only as a server environment variable, never with a VITE_ prefix. ---
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
